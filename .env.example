# ============================================================================
# WORKSHOP CONFIGURATION
# ============================================================================

# Default model for all agents in the workshop
# Examples: "anthropic:claude-haiku-4-5", "openai:gpt-5-mini", "openai:gpt-4o"
# Can be overridden per-agent in factory functions
WORKSHOP_MODEL="openai:gpt-5-mini"

# Embedding provider for document vectorstore
# Options: "huggingface" (default, local model, no API key) or "openai" (requires OPENAI_API_KEY)
# Note: Changing providers requires rebuilding the vectorstore:
#   uv run python data/data_generation/build_vectorstore.py
# EMBEDDING_PROVIDER="huggingface"

# ============================================================================
# LANGSMITH CONFIGURATION
# ============================================================================

# Optional for LangSmith tracing and experiment tracking
LANGSMITH_TRACING="true"
LANGSMITH_PROJECT="<initials>-langsmith-agent-lifecycle-workshop"
LANGSMITH_API_KEY="<langsmith-api-key>"
LANGSMITH_ENDPOINT="<langsmith-endpoint>" # defaults to https://api.smith.langchain.com if using cloud
#LANGSMITH_WORKSPACE_ID="<langsmith-workspace-id>"

# ============================================================================
# MODEL PROVIDER API KEYS
# ============================================================================

# If using OpenAI 
OPENAI_API_KEY="<openai-api-key>"
#OPENAI_BASE_URL="<openai-base-url>" # Optional, if different from the default 
# OPENAI_CA_BUNDLE="/absolute/path/to/company-root-ca.pem" # Optional, for corporate TLS interception
OPENAI_SSL_VERIFY="false" # Last resort for local development only (disables TLS verification)

# If using Azure OpenAI
AZURE_OPENAI_API_KEY="<azure-openai-api-key>"
AZURE_OPENAI_ENDPOINT="<azure-openai-endpoint>"
AZURE_OPENAI_API_VERSION=""

# If using Anthropic
ANTHROPIC_API_KEY="<anthropic-api-key>"

# If using AWS
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
AWS_REGION_NAME=""
AWS_MODEL_ARN=""

# ============================================================================
# DEPLOYMENT CONFIGURATION (Optional)
# ============================================================================

# LangGraph deployment URL for simulation system
# Only needed if running automated simulations against deployed graphs
# Example: "https://your-deployment.us.langgraph.app"
LANGRAPH_DEPLOYMENT_URL=""
